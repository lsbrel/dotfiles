  "window_width": 480,
  "window_height": 680,
  "layer_shell_layer": "overlay",
  "position": "top-right",
  "layer_shell_margin_top": 8,
  "layer_shell_margin_right": 8,
  "layer_shell_margin_bottom": 8,
  "layer_shell_margin_left": 8,
  "log_level": "info",
  "load_core_styles": true,

  "scan_interval": 20,
  "close_on_connect": false,
